<Window x:Class="WranglerTray.Views.DeploymentListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:WranglerTray.Models"
        Title="Wrangler Tray — Deployments"
        Width="420" Height="520"
        WindowStyle="ToolWindow"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#1e1e2e">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="☁️ Deployments" FontSize="18" FontWeight="SemiBold" 
                       Foreground="#cdd6f4" DockPanel.Dock="Left"/>
            <Button Content="⟳" Command="{Binding RefreshCommand}" 
                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                    Background="Transparent" Foreground="#89b4fa" BorderThickness="0"
                    FontSize="18" Cursor="Hand" Padding="6,2"
                    ToolTip="Refresh now"/>
        </DockPanel>

        <!-- Not authenticated message -->
        <TextBlock Grid.Row="1" 
                   Text="Not logged in. Open Settings to connect your Cloudflare account."
                   Foreground="#a6adc8" TextWrapping="Wrap" Margin="0,20"
                   HorizontalAlignment="Center" VerticalAlignment="Top"
                   Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="1" Text="Checking deployments..." 
                   Foreground="#a6adc8" HorizontalAlignment="Center" VerticalAlignment="Top"
                   Margin="0,20"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- Error message -->
        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                   Foreground="#f38ba8" TextWrapping="Wrap" Margin="0,40,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"/>

        <!-- Deployment list -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Deployments}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Margin="0,5">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Background" Value="#313244"/>
                    <Setter Property="Foreground" Value="#cdd6f4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Margin="{TemplateBinding Margin}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#45475a"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:Deployment}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Status indicator -->
                        <Ellipse Grid.Column="0" Grid.RowSpan="2" 
                                 Width="10" Height="10" Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#6c7086"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                            <Setter Property="Fill" Value="#a6e3a1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Failure">
                                            <Setter Property="Fill" Value="#f38ba8"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Active">
                                            <Setter Property="Fill" Value="#89b4fa"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Queued">
                                            <Setter Property="Fill" Value="#f9e2af"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Project name + type badge -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" 
                                       Foreground="#cdd6f4" FontSize="13"/>
                            <Border CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#45475a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Worker">
                                                <Setter Property="Background" Value="#3b3d5e"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Pages">
                                                <Setter Property="Background" Value="#3b5e3d"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="10" Foreground="#bac2de">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Worker">
                                                    <Setter Property="Text" Value="⚡ Worker"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Pages">
                                                    <Setter Property="Text" Value="📄 Pages"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Time ago -->
                        <TextBlock Grid.Column="2" Grid.Row="0" 
                                   Text="{Binding TimeAgo}" Foreground="#6c7086" 
                                   FontSize="11" VerticalAlignment="Center"/>

                        <!-- Commit info -->
                        <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                   Foreground="#a6adc8" FontSize="11" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding ShortCommitHash, Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding CommitMessage, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⚙️" Command="{Binding OpenSettingsCommand}" 
                        Background="Transparent" Foreground="#6c7086" BorderThickness="0"
                        FontSize="14" Cursor="Hand" Padding="4,0" ToolTip="Settings"/>
                <Button Content="✕" Command="{Binding ExitCommand}" 
                        Background="Transparent" Foreground="#f38ba8" BorderThickness="0"
                        FontSize="14" Cursor="Hand" Padding="4,0" ToolTip="Exit Wrangler Tray"
                        Margin="4,0,0,0"/>
            </StackPanel>
            <TextBlock Foreground="#6c7086" FontSize="11" VerticalAlignment="Center">
                <Run Text="Last checked: "/>
                <Run Text="{Binding LastCheckedText, Mode=OneWay}"/>
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
