<Window x:Class="WranglerTray.Views.DeploymentListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:WranglerTray.Models"
        Title="Wrangler Tray — Deployments"
        Width="420" Height="520"
        WindowStyle="ToolWindow"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#1e1e2e">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="☁️ Deployments" FontSize="18" FontWeight="SemiBold" 
                       Foreground="#cdd6f4" DockPanel.Dock="Left"/>

            <!-- Pin toggle -->
            <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding IsPinned}"
                          Background="Transparent" BorderThickness="0"
                          Cursor="Hand" Padding="6,2"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right" Margin="4,0,0,0"
                          ToolTip="Pin window (keep open)">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="PinIcon" Text="📌" FontSize="16"
                                       FontFamily="Segoe UI Emoji"
                                       VerticalAlignment="Center"
                                       Opacity="0.4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PinIcon" Property="Opacity" Value="1.0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PinIcon" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>

            <!-- Refresh button: hidden while loading -->
            <Button Content="⟳" Command="{Binding RefreshCommand}" 
                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent" Foreground="#89b4fa" BorderThickness="0"
                    FontSize="18" Cursor="Hand" Padding="6,2"
                    ToolTip="Refresh now">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Spinning indicator: shown while loading -->
            <Border DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="6,2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="⏳" FontSize="16" Foreground="#89b4fa"
                           RenderTransformOrigin="0.5,0.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.RenderTransform>
                        <RotateTransform/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0" To="360" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </Border>
        </DockPanel>

        <!-- Project tabs -->
        <ListBox Grid.Row="0" Margin="0,36,0,0"
                 ItemsSource="{Binding ProjectNames}"
                 SelectedItem="{Binding SelectedProject}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="10,4"/>
                    <Setter Property="Margin" Value="0,0,4,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Foreground" Value="#6c7086"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" CornerRadius="4" 
                                        Padding="{TemplateBinding Padding}"
                                        Margin="{TemplateBinding Margin}"
                                        Background="Transparent"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#89b4fa"/>
                                        <Setter Property="Foreground" Value="#cdd6f4"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background" Value="#25253a"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="12"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status messages (mutually exclusive, all in Row 1) -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,20"
                    HorizontalAlignment="Center">
            <TextBlock Text="Not logged in. Open Settings to connect your Cloudflare account."
                       Foreground="#a6adc8" TextWrapping="Wrap" TextAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="Checking deployments..." 
                       Foreground="#a6adc8" TextAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsAuthenticated}" Value="True"/>
                                    <Condition Binding="{Binding IsLoading}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="#f38ba8" TextWrapping="Wrap" TextAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsAuthenticated}" Value="True"/>
                                    <Condition Binding="{Binding IsLoading}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Deployment list -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Deployments}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Margin="0,5"
                 x:Name="DeploymentList"
                 MouseDoubleClick="DeploymentList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Background" Value="#313244"/>
                    <Setter Property="Foreground" Value="#cdd6f4"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Margin="{TemplateBinding Margin}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#45475a"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:Deployment}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Status indicator -->
                        <Ellipse Grid.Column="0" Grid.RowSpan="2" 
                                 Width="10" Height="10" Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#6c7086"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                            <Setter Property="Fill" Value="#a6e3a1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Failure">
                                            <Setter Property="Fill" Value="#f38ba8"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Active">
                                            <Setter Property="Fill" Value="#89b4fa"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Queued">
                                            <Setter Property="Fill" Value="#f9e2af"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Project name + type badge -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" 
                                       Foreground="#cdd6f4" FontSize="13"/>
                            <Border CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#45475a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Worker">
                                                <Setter Property="Background" Value="#3b3d5e"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Pages">
                                                <Setter Property="Background" Value="#3b5e3d"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="10" Foreground="#bac2de">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Worker">
                                                    <Setter Property="Text" Value="⚡ Worker"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Pages">
                                                    <Setter Property="Text" Value="📄 Pages"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Time ago -->
                        <TextBlock Grid.Column="2" Grid.Row="0" 
                                   Text="{Binding TimeAgo}" Foreground="#6c7086" 
                                   FontSize="11" VerticalAlignment="Center"/>

                        <!-- Commit info -->
                        <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                   Foreground="#a6adc8" FontSize="11" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding ShortCommitHash, Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding CommitMessage, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⚙️" Command="{Binding OpenSettingsCommand}" 
                        Background="Transparent" Foreground="#6c7086" BorderThickness="0"
                        FontSize="14" Cursor="Hand" Padding="4,0" ToolTip="Settings"/>
                <Button Content="✕" Command="{Binding ExitCommand}" 
                        Background="Transparent" Foreground="#f38ba8" BorderThickness="0"
                        FontSize="14" Cursor="Hand" Padding="4,0" ToolTip="Exit Wrangler Tray"
                        Margin="4,0,0,0"/>
            </StackPanel>
            <TextBlock Foreground="#6c7086" FontSize="11" VerticalAlignment="Center">
                <Run Text="Last checked: "/>
                <Run Text="{Binding LastCheckedText, Mode=OneWay}"/>
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
